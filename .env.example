# REVERIE — Environment Variables
# Copy this file, rename it to .env, and fill in your real keys.
# NEVER commit .env to GitHub — it's already in .gitignore.

# Get your free Gemini key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get your free ElevenLabs key at: https://elevenlabs.io (sign up → profile → API key)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
